<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_advance_payment_list" model="ir.ui.view">
        <field name="name">sale.advance.payment.list</field>
        <field name="model">sale.advance.payment</field>
        <field name="arch" type="xml">
            <list string="Advances">
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="payment_id"/>
                <field name="statement_line_id" optional="hide"/>
                <field name="amount" sum="Total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'received'"
                       decoration-success="state == 'allocated'"/>
            </list>
        </field>
    </record>

    <record id="view_sale_advance_payment_form" model="ir.ui.view">
        <field name="name">sale.advance.payment.form</field>
        <field name="model">sale.advance.payment</field>
        <field name="arch" type="xml">
            <form string="Advance">
                <sheet>
                    <group>
                        <group>
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="payment_id"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="statement_line_id"/>
                            <field name="move_line_id"/>
                            <field name="state" widget="badge"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sale_advance_payment_search" model="ir.ui.view">
        <field name="name">sale.advance.payment.search</field>
        <field name="model">sale.advance.payment</field>
        <field name="arch" type="xml">
            <search>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="payment_id"/>
                <filter name="received" string="Received"
                        domain="[('state', '=', 'received')]"/>
                <filter name="allocated" string="Allocated"
                        domain="[('state', '=', 'allocated')]"/>
                <separator/>
                <filter name="group_partner" string="Customer"
                        domain="[]" context="{'group_by': 'partner_id'}"/>
                <filter name="group_state" string="Status"
                        domain="[]" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_sale_advance_payment" model="ir.actions.act_window">
        <field name="name">Sale Order Advances</field>
        <field name="res_model">sale.advance.payment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False}</field>
    </record>

    <menuitem id="menu_sale_advance_payment"
              name="Sale Order Advances"
              parent="account.menu_finance_receivables"
              action="action_sale_advance_payment"
              sequence="99"/>

</odoo>
